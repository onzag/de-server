# Use ROCm PyTorch base image (Ubuntu 22.04 + ROCm + PyTorch)
FROM rocm/pytorch:5.4.2_ubuntu22.04_py3.10_pytorch_2.2.0

# Update and install basic utilities
RUN apt-get update -y \
    && apt-get install -y python3-pip

# Upgrade pip
RUN python3 -m pip install --upgrade pip

# Install vLLM (ROCm will auto-detect the ROCm backend)
RUN python3 -m pip install "vllm[flashinfer]==0.15.0"

# Copy your requirements file
COPY requirements.txt /requirements.txt

# Install requirements (with pip cache mount if using BuildKit)
RUN --mount=type=cache,target=/root/.cache/pip \
    python3 -m pip install --upgrade -r /requirements.txt

# Copy your application code
COPY handler.py /handler.py
COPY base.py /base.py

# Default command
CMD [ "python3", "/handler.py" ]